// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  username  String   @unique
  shortId   String   @unique // 4-digit ID like "1024"
  pinHash   String   // bcrypt hashed 6-digit PIN
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  transactionsAsInitiator   Transaction[] @relation("initiator")
  transactionsAsCounterparty Transaction[] @relation("counterparty")
}

model Transaction {
  id             String   @id @default(cuid())
  amount         Float    // Amount in primary currency (USD, etc.)
  description    String
  status         String   @default("PENDING") // PENDING, CONFIRMED
  paidBy         String   // "INITIATOR" or "COUNTERPARTY"
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  // Relations
  initiatorId    String
  initiator      User     @relation("initiator", fields: [initiatorId], references: [id], onDelete: Cascade)
  counterpartyId String
  counterparty   User     @relation("counterparty", fields: [counterpartyId], references: [id], onDelete: Cascade)

  @@index([initiatorId])
  @@index([counterpartyId])
  @@index([status])
}
